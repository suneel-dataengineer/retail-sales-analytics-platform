							"inputs": [
								{
									"referenceName": "ds_adls_sales_csv",
									"type": "DatasetReference",
									"parameters": {
										"fileName": {
											"value": "@item().name",
											"type": "Expression"
										}
									}
								}
							],
							"outputs": [
								{
									"referenceName": "ds_sql_salesfact",
									"type": "DatasetReference"
								}
							]
						}
					]
				}
			},
